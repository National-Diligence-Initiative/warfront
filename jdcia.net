
using System.Net.Http.Headers;
using System.Security.Cryptography;
using System.Text;
using System.Text.Json;

// ==============================
// CONTRACTS
// ==============================

// ==============================
// SOURCE-GENERATED LOGGING
// ==============================

public static partial class CovaxLog
{
    [LoggerMessage(
        EventId = 1001,
        Level = LogLevel.Information,
        Message = "Prepared Covax request {Operation} {CorrelationId} payload={Payload}")]
    public static partial void PreparedRequest(
        ILogger logger,
        string operation,
        string correlationId,
        [CovaxClassifications.Private] string payload);

    [LoggerMessage(
        EventId = 1002,
        Level = LogLevel.Information,
        Message = "Received Covax response {StatusCode} {CorrelationId} payload={Payload}")]
    public static partial void ReceivedResponse(
        ILogger logger,
        int statusCode,
        string correlationId,
        [CovaxClassifications.Private] string payload);
}

// ==============================
// ADAPTER PATCH
// ==============================

public sealed class CovaxAdapter : ICovaxAdapter
{
    private readonly HttpClient _http;
    private readonly CovaxAdapterOptions _options;
    private readonly AuditLedger _ledger;
    private readonly string _scope;
    private readonly CovaxAutoRedactor _autoRedactor;
    private readonly ILogger<CovaxAdapter> _logger;

    public CovaxAdapter(
        HttpClient http,
        CovaxAdapterOptions options,
        AuditLedger ledger,
        string scope,
        CovaxAutoRedactor autoRedactor,
        ILogger<CovaxAdapter> logger)
    {
        _http = http;
        _options = options;
        _ledger = ledger;
        _scope = scope;
        _autoRedactor = autoRedactor;
        _logger = logger;
    }

    public async Task<CovaxResponse> SendAsync(CovaxRequest request, CancellationToken ct = default)
    {
        ValidateScope();
        ValidateRequest(request);

        // Auto-redact only for logs/audit. Do not mutate the outbound payload here.
        var redactedPayload = _autoRedactor.RedactJson(request.PayloadJson);

        _ledger.Append(
            "covax.request.prepare",
            request.CorrelationId,
            $"{request.Operation}|{redactedPayload}");

        CovaxLog.PreparedRequest(
            _logger,
            request.Operation,
            request.CorrelationId,
            redactedPayload);

        var canonical = $"{request.CorrelationId}|{request.Operation}|{request.PayloadJson}";
        var signature = Hashing.HmacBase64(_options.HmacSecret, canonical);

        using var msg = new HttpRequestMessage(HttpMethod.Post, BuildUri(request.Operation));
        msg.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _options.ApiKey);
        msg.Headers.Add("X-Correlation-Id", request.CorrelationId);
        msg.Headers.Add("X-Covax-Signature", signature);
        msg.Content = new StringContent(request.PayloadJson, System.Text.Encoding.UTF8, "application/json");

        HttpResponseMessage rsp;
        try
        {
            rsp = await _http.SendAsync(msg, ct).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _ledger.Append("covax.request.error", request.CorrelationId, ex.Message);
            _logger.LogError(ex, "Covax transport error for {CorrelationId}", request.CorrelationId);

            return new CovaxResponse
            {
                Ok = false,
                StatusCode = 0,
                Message = $"Transport error: {ex.Message}"
            };
        }

        var body = await rsp.Content.ReadAsStringAsync(ct).ConfigureAwait(false);
        var redactedResponse = _autoRedactor.RedactJson(body);

        _ledger.Append("covax.response.received", request.CorrelationId, redactedResponse);

        CovaxLog.ReceivedResponse(
            _logger,
            (int)rsp.StatusCode,
            request.CorrelationId,
            redactedResponse);

        return new CovaxResponse
        {
            Ok = rsp.IsSuccessStatusCode,
            StatusCode = (int)rsp.StatusCode,
            Message = rsp.ReasonPhrase ?? "",
            BodyJson = body
        };
    }

    private void ValidateScope()
    {
        if (!_options.AllowedScopes.Contains(_scope))
            throw new UnauthorizedAccessException($"Scope '{_scope}' is not permitted.");
    }

    private void ValidateRequest(CovaxRequest request)
    {
        if (string.IsNullOrWhiteSpace(request.CorrelationId))
            throw new ArgumentException("CorrelationId is required.");

        if (string.IsNullOrWhiteSpace(request.Operation))
            throw new ArgumentException("Operation is required.");

        if (!_options.AllowedOperations.Contains(request.Operation))
            throw new InvalidOperationException($"Operation '{request.Operation}' is not allowlisted.");

        if (request.PayloadJson.Length > 250_000)
            throw new InvalidOperationException("Payload too large.");
    }

    private Uri BuildUri(string operation)
    {
        var baseUri = _options.BaseUrl.EndsWith("/") ? _options.BaseUrl : _options.BaseUrl + "/";
        return new Uri($"{baseUri}api/covax/{operation.Replace('.', '/')}");
    }
}

// ==============================
// AUTO REDACTOR
// ==============================

public sealed class CovaxAutoRedactor
{
    private readonly IRedactorProvider _provider;

    // Field-name to classification map.
    private static readonly Dictionary<string, DataClassification> FieldMap =
        new(StringComparer.OrdinalIgnoreCase)
        {
            ["ssn"] = CovaxClassifications.Secret,
            ["socialsecuritynumber"] = CovaxClassifications.Secret,
            ["dob"] = CovaxClassifications.Private,
            ["birthdate"] = CovaxClassifications.Private,
            ["passport"] = CovaxClassifications.Secret,
            ["driverlicense"] = CovaxClassifications.Secret,
            ["license"] = CovaxClassifications.Private,
            ["apikey"] = CovaxClassifications.Secret,
            ["token"] = CovaxClassifications.Secret,
            ["secret"] = CovaxClassifications.Secret,
            ["authorization"] = CovaxClassifications.Secret,
            ["email"] = CovaxClassifications.Private,
            ["phone"] = CovaxClassifications.Private,
            ["caseid"] = CovaxClassifications.Correlatable,
            ["subjectid"] = CovaxClassifications.Correlatable,
            ["recordid"] = CovaxClassifications.Correlatable
        };

    public CovaxAutoRedactor(IRedactorProvider provider)
    {
        _provider = provider;
    }

    public string RedactJson(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return "{}";

        JsonNode? node = JsonNode.Parse(json);
        if (node is null)
            return "{}";

        RedactNode(node, parentKey: null);
        return node.ToJsonString(new JsonSerializerOptions { WriteIndented = false });
    }

    private void RedactNode(JsonNode node, string? parentKey)
    {
        if (node is JsonObject obj)
        {
            foreach (var kvp in obj.ToList())
            {
                if (kvp.Value is null) continue;

                if (kvp.Value is JsonValue val)
                {
                    obj[kvp.Key] = RedactValue(kvp.Key, val);
                }
                else
                {
                    RedactNode(kvp.Value, kvp.Key);
                }
            }

            return;
        }

        if (node is JsonArray arr)
        {
            for (int i = 0; i < arr.Count; i++)
            {
                var item = arr[i];
                if (item is null) continue;

                if (item is JsonValue val)
                {
                    arr[i] = RedactValue(parentKey ?? "value", val);
                }
                else
                {
                    RedactNode(item, parentKey);
                }
            }
        }
    }

    private JsonNode RedactValue(string fieldName, JsonValue value)
    {
        if (!FieldMap.TryGetValue(Normalize(fieldName), out var classification))
            return value;

        var raw = value.ToJsonString().Trim('"');
        var redactor = _provider.GetRedactor(new DataClassificationSet(classification));
        var redacted = redactor.Redact(raw);

        return JsonValue.Create(redacted)!;
    }

    private static string Normalize(string input) =>
        new string(input.Where(char.IsLetterOrDigit).ToArray()).ToLowerInvariant();
}

