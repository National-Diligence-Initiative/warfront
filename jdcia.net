// DI REGISTRATION
// ==============================

var services = new ServiceCollection();

services.AddLogging(builder =>
{
    builder.EnableRedaction();
    builder.AddSimpleConsole();
});

services.AddRedaction(builder =>
{
    // Full erase for secrets/private fields.
    builder.SetRedactor<ErasingRedactor>(
        CovaxClassifications.Secret,
        CovaxClassifications.Private);

    // Optional: use HMAC for correlatable IDs instead of plain erase.
    // builder.SetHmacRedactor(
    //     options =>
    //     {
    //         options.KeyId = 1;
    //         options.Key = "BASE64_ENCODED_KEY_AT_LEAST_44_CHARS_LONG_HERE";
    //     },
    //     CovaxClassifications.Correlatable);
});

services.AddSingleton<CovaxAutoRedactor>();

using Microsoft.Extensions.Compliance.Classification;
