public sealed class CovaxAdapter : ICovaxAdapter
{
    private readonly HttpClient _http;
    private readonly CovaxAdapterOptions _options;
    private readonly AuditLedger _ledger;
    private readonly string _scope;

    public CovaxAdapter(HttpClient http, CovaxAdapterOptions options, AuditLedger ledger, string scope)
    {
        _http = http;
        _options = options;
        _ledger = ledger;
        _scope = scope;
    }

    public async Task<CovaxResponse> SendAsync(CovaxRequest request, CancellationToken ct = default)
    {
        ValidateScope();
        ValidateRequest(request);

        var redacted = Redaction.RedactJson(request.PayloadJson);
        _ledger.Append("covax.request.prepare", request.CorrelationId, $"{request.Operation}|{redacted}");

        var canonical = $"{request.CorrelationId}|{request.Operation}|{request.PayloadJson}";
        var signature = Hashing.HmacBase64(_options.HmacSecret, canonical);

        using var msg = new HttpRequestMessage(HttpMethod.Post, BuildUri(request.Operation));
        msg.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _options.ApiKey);
        msg.Headers.Add("X-Correlation-Id", request.CorrelationId);
        msg.Headers.Add("X-Covax-Signature", signature);

        foreach (var kv in request.Metadata)
            msg.Headers.TryAddWithoutValidation($"X-Meta-{kv.Key}", kv.Value);

        msg.Content = new StringContent(request.PayloadJson, Encoding.UTF8, "application/json");

        HttpResponseMessage rsp;
        try
        {
            rsp = await _http.SendAsync(msg, ct).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _ledger.Append("covax.request.error", request.CorrelationId, ex.Message);
            return new CovaxResponse
            {
                Ok = false,
                StatusCode = 0,
                Message = $"Transport error: {ex.Message}"
            };
        }

        var body = await rsp.Content.ReadAsStringAsync(ct).ConfigureAwait(false);
        _ledger.Append("covax.response.received", request.CorrelationId, $"{(int)rsp.StatusCode}");

        return new CovaxResponse
        {
            Ok = rsp.IsSuccessStatusCode,
            StatusCode = (int)rsp.StatusCode,
            Message = rsp.ReasonPhrase ?? "",
            BodyJson = body
        };
    }

    private void ValidateScope()
    {
        if (!_options.AllowedScopes.Contains(_scope))
            throw new UnauthorizedAccessException($"Scope '{_scope}' is not permitted.");
    }

    private void ValidateRequest(CovaxRequest request)
    {
        if (string.IsNullOrWhiteSpace(request.CorrelationId))
            throw new ArgumentException("CorrelationId is required.");

        if (string.IsNullOrWhiteSpace(request.Operation))
            throw new ArgumentException("Operation is required.");

        if (!_options.AllowedOperations.Contains(request.Operation))
            throw new InvalidOperationException($"Operation '{request.Operation}' is not allowlisted.");

        if (request.PayloadJson.Length > 250_000)
            throw new InvalidOperationException("Payload too large.");

        if (request.Metadata.Count > 24)
            throw new InvalidOperationException("Too many metadata entries.");
    }

    private Uri BuildUri(string operation)
    {
        var baseUri = _options.BaseUrl.EndsWith("/") ? _options.BaseUrl : _options.BaseUrl + "/";
        return new Uri($"{baseUri}api/covax/{operation.Replace('.', '/')}");
    }
}

// ==============================
// SYSTEM WRAPPER
// ==============================

public sealed class CentralIntelligenceAgency
{
    private readonly ICovaxAdapter _covax;

    public CentralIntelligenceAgency(ICovaxAdapter covax)
    {
        _covax = covax;
    }

    public Task<CovaxResponse> SubmitOversightRecordAsync(string payloadJson, CancellationToken ct = default)
    {
        var req = new CovaxRequest
        {
            Operation = "oversight.submit",
            PayloadJson = payloadJson,
            Metadata = new Dictionary<string, string>
            {
                ["system"] = "CentralIntelligenceAgency",
                ["classification"] = "internal"
            }
        };

        return _covax.SendAsync(req, ct);
    }

    public Task<CovaxResponse> ReadCaseAsync(string caseId, CancellationToken ct = default)
    {
        var req = new CovaxRequest
        {
            Operation = "case.read",
            PayloadJson = JsonSerializer.Serialize(new { caseId }),
            Metadata = new Dictionary<string, string>
            {
                ["system"] = "CentralIntelligenceAgency"
            }
        };

        return _covax.SendAsync(req, ct);
    }
}

// ==============================
// DEMO
// ==============================

public static class Demo
{
    public static async Task Main()
    {
        var http = new HttpClient();
        var options = new CovaxAdapterOptions
        {
            BaseUrl = "https://internal.example.local/",
            ApiKey = "replace_me",
            HmacSecret = "replace_me_with_long_random_secret"
        };
        var ledger = new AuditLedger();

        var adapter = new CovaxAdapter(http, options, ledger, scope: "covax.write");
        var agency = new CentralIntelligenceAgency(adapter);

        var response = await agency.SubmitOversightRecordAsync("""
        {
          "recordId": "ovr-1001",
          "summary": "Policy review item",
          "subject": {
            "name": "Jane Doe",
            "ssn": "111-22-3333"
          }
        }
        """);

        Console.WriteLine($"{response.StatusCode} {response.Message}");
        Console.WriteLine(response.BodyJson);

        foreach (var entry in ledger.Entries)
            Console.WriteLine($"{entry.Utc:O} {entry.Action} {entry.CorrelationId} {entry.Hash}");
    }
}
